{
  "version": 1,
  "name": "settings_page",
  "root": {
    "type": "Panel",
    "props": {},
    "style": {
      "layout": "vertical",
      "bgColor": "#1a1a2e",
      "padding": 20,
      "gap": 12,
      "width": 500,
      "height": 400
    },
    "children": [
      {
        "type": "Text",
        "props": {
          "value": "设置"
        },
        "style": {
          "color": "#FFFFFF",
          "fontSize": 24,
          "bold": true
        },
        "id": "settings_title"
      },
      {
        "type": "Panel",
        "props": {},
        "style": {
          "layout": "horizontal",
          "gap": 10
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "value": "音量"
            },
            "style": {
              "color": "#CCCCCC",
              "fontSize": 16,
              "width": 80
            }
          },
          {
            "type": "Slider",
            "props": {
              "min": 0,
              "max": 100,
              "value": 80
            },
            "style": {
              "width": 200
            },
            "id": "volume_slider"
          }
        ]
      },
      {
        "type": "Panel",
        "props": {},
        "style": {
          "layout": "horizontal",
          "gap": 10
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "value": "昵称"
            },
            "style": {
              "color": "#CCCCCC",
              "fontSize": 16,
              "width": 80
            }
          },
          {
            "type": "Input",
            "props": {
              "placeholder": "请输入昵称",
              "value": "Player1"
            },
            "style": {
              "bgColor": "#16213e",
              "color": "#FFFFFF",
              "fontSize": 14,
              "cornerRadius": 4,
              "width": 200,
              "height": 30,
              "border": {}
            },
            "id": "name_input"
          }
        ]
      },
      {
        "type": "Panel",
        "props": {},
        "style": {
          "layout": "horizontal",
          "gap": 10
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "value": "音效"
            },
            "style": {
              "color": "#CCCCCC",
              "fontSize": 16,
              "width": 80
            }
          },
          {
            "type": "Button",
            "props": {
              "text": ""
            },
            "style": {
              "bgColor": "#0f3460",
              "cornerRadius": 12,
              "width": 48,
              "height": 24,
              "border": {}
            },
            "id": "sfx_toggle"
          }
        ]
      },
      {
        "type": "Panel",
        "props": {},
        "style": {
          "layout": "horizontal",
          "gap": 10
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "value": "背景音乐"
            },
            "style": {
              "color": "#CCCCCC",
              "fontSize": 16,
              "width": 80
            }
          },
          {
            "type": "Button",
            "props": {
              "text": ""
            },
            "style": {
              "bgColor": "#0f3460",
              "cornerRadius": 12,
              "width": 48,
              "height": 24,
              "border": {}
            },
            "id": "bgm_toggle"
          }
        ]
      },
      {
        "type": "Button",
        "props": {
          "text": "保存"
        },
        "style": {
          "bgColor": "#0f3460",
          "color": "#FFFFFF",
          "fontSize": 14,
          "cornerRadius": 4,
          "width": 120,
          "height": 36,
          "border": {}
        },
        "id": "save_btn"
      }
    ]
  }
}